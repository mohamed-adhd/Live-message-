<UserControl
    xmlns="https://github.com/avaloniaui"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
    xmlns:vm="using:live_message_app.ViewModels"
    x:Class="live_message_app.Views.register"
    x:DataType="vm:RegisterViewModel">
    <Grid>
        <Button Content="go to login" Command="{Binding GoToLoginCommand}"/>
        <StackPanel>
            <TextBox PlaceholderText="name" Background="DarkGray"></TextBox>
            <TextBox PlaceholderText="username" Background="DarkGray"></TextBox>
            <TextBox PlaceholderText="password" Background="DarkGray"></TextBox>
            <TextBox PlaceholderText="confirm password" Background="DarkGray"></TextBox>
            <TextBox PlaceholderText="gmail" Background="DarkGray"></TextBox>
            <Button Content="register" Command="{Binding }"></Button>
        </StackPanel>
    </Grid>
</UserControl>

