<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        x:Class="live_message_app.Views.MainWindow"
        Width="1200"
        Height="720"
        Title="Live Messenger">

    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="300"/>
            <ColumnDefinition Width="*"/>
        </Grid.ColumnDefinitions>
        <TextBlock Text="chats" VerticalAlignment="Top" HorizontalAlignment="Center" Grid.Column="0" FontSize="30"/>
        <TextBlock Text="users" VerticalAlignment="Top" HorizontalAlignment="Center" Grid.Column="1"  FontSize="30"/>
    </Grid>
    
    
</Window>